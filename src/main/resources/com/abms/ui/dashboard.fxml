<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<BorderPane xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.abms.ui.DashboardController" stylesheets="@css/style.css">
    
    <!-- Sidebar -->
    <left>
        <VBox spacing="10" prefWidth="250" styleClass="sidebar">
            <padding>
                <Insets top="20" bottom="20" left="0" right="0" />
            </padding>
            <HBox alignment="CENTER" spacing="10">
                <ImageView fitHeight="50.0" fitWidth="50.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../../../images/animal.png" />
                    </image>
                </ImageView>
                <Label text="ABMS" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 20px;" />
            </HBox>
            <Separator style="-fx-padding: 10 20;" />
            <Button text="Dashboard Home" styleClass="sidebar-button" maxWidth="Infinity" />
            <Button text="Patient Registration" onAction="#showPatientManagement" styleClass="sidebar-button" maxWidth="Infinity" />
            <Button text="Vaccination Schedule" onAction="#showVaccinationMonitoring" styleClass="sidebar-button" maxWidth="Infinity" />
            <Button text="Reports &amp; Analytics" onAction="#showReportsAnalytics" styleClass="sidebar-button" maxWidth="Infinity" />
            
            <VBox fx:id="adminBox" spacing="10" managed="false" visible="false">
                <Separator style="-fx-padding: 5 20;" />
                <Label text="ADMIN PANEL" style="-fx-text-fill: -fx-highlight-orange; -fx-font-size: 11px; -fx-padding: 0 20;" />
                <Button text="User Management" onAction="#showUserManagement" styleClass="sidebar-button" maxWidth="Infinity" />
                <Button text="System Activity Logs" onAction="#showSystemLogs" styleClass="sidebar-button" maxWidth="Infinity" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />
            <Button text="Logout" onAction="#handleLogout" styleClass="sidebar-button" maxWidth="Infinity" style="-fx-background-color: rgba(255,0,0,0.2);" />
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <VBox spacing="20" styleClass="root">
            <padding>
                <Insets top="30" left="30" right="30" bottom="30" />
            </padding>
            <Label fx:id="welcomeLabel" text="Welcome, User" styleClass="label-header" />
            
            <HBox spacing="20">
                <VBox styleClass="card" prefWidth="200">
                    <Label text="Today's Cases" style="-fx-font-weight: bold;" />
                    <Label fx:id="todayCasesLabel" text="0" style="-fx-font-size: 36px; -fx-text-fill: -fx-primary-blue;" />
                </VBox>
                <VBox styleClass="card" prefWidth="200">
                    <Label text="Pending Vaccinations" style="-fx-font-weight: bold;" />
                    <Label fx:id="pendingVaccLabel" text="0" style="-fx-font-size: 36px; -fx-text-fill: -fx-highlight-orange;" />
                </VBox>
                <VBox styleClass="card" prefWidth="200">
                    <Label text="Completed Doses" style="-fx-font-weight: bold;" />
                    <Label fx:id="completedDosesLabel" text="0" style="-fx-font-size: 36px; -fx-text-fill: -fx-success-green;" />
                </VBox>
            </HBox>
            
            <VBox VBox.vgrow="ALWAYS" styleClass="card">
                <Label text="Recent Activity" styleClass="label-header" style="-fx-font-size: 18px;" />
                <ListView fx:id="activityList" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-width: 0;" />
            </VBox>
        </VBox>
    </center>
</BorderPane>
