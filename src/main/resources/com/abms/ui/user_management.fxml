<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<VBox spacing="20" styleClass="root" stylesheets="@css/style.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.abms.ui.UserManagementController">
    <padding>
        <Insets top="20" left="20" right="20" bottom="20" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Button text="← Back" onAction="#goBack" style="-fx-background-color: transparent; -fx-text-fill: -fx-primary-blue;" />
        <ImageView fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="@images/logo.png" />
            </image>
        </ImageView>
        <Label text="User Management (Admin)" styleClass="label-header" />
    </HBox>

    <HBox VBox.vgrow="ALWAYS" spacing="20">
        <!-- User Form -->
        <VBox prefWidth="300" spacing="15" styleClass="card">
            <Label text="User Details" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: -fx-primary-blue;" />
            
            <VBox spacing="5">
                <Label text="Full Name" />
                <TextField fx:id="fullNameField" promptText="Enter full name" />
            </VBox>
            
            <VBox spacing="5">
                <Label text="Username" />
                <TextField fx:id="usernameField" promptText="Enter username" />
            </VBox>
            
            <VBox spacing="5">
                <Label text="Password" />
                <PasswordField fx:id="passwordField" promptText="Enter password" />
            </VBox>
            
            <VBox spacing="5">
                <Label text="Role" />
                <ComboBox fx:id="roleComboBox" promptText="Select Role" maxWidth="Infinity" />
            </VBox>
            
            <HBox spacing="10">
                <Button fx:id="saveButton" text="Add User" onAction="#handleSave" styleClass="button-primary" maxWidth="Infinity" HBox.hgrow="ALWAYS" />
                <Button text="Clear" onAction="#handleClear" style="-fx-background-color: -fx-light-gray;" />
            </HBox>
        </VBox>

        <!-- User Table -->
        <VBox HBox.hgrow="ALWAYS" spacing="10" styleClass="card">
            <Label text="Register Users" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: -fx-primary-blue;" />
            <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idCol" text="ID" prefWidth="50" />
                    <TableColumn fx:id="fullNameCol" text="Full Name" prefWidth="150" />
                    <TableColumn fx:id="usernameCol" text="Username" prefWidth="120" />
                    <TableColumn fx:id="roleCol" text="Role" prefWidth="100" />
                    <TableColumn fx:id="actionsCol" text="Actions" prefWidth="150" />
                </columns>
            </TableView>
        </VBox>
    </HBox>
</VBox>
