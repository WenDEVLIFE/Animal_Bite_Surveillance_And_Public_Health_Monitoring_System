<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.chart.PieChart?>

<VBox spacing="20" styleClass="root" stylesheets="@css/style.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.abms.ui.ReportController">
    <padding>
        <Insets top="20" left="20" right="20" bottom="20" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Button text="← Back" onAction="#goBack" style="-fx-background-color: transparent; -fx-text-fill: -fx-primary-blue;" />
        <ImageView fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="@images/logo.png" />
            </image>
        </ImageView>
        <Label text="Reports &amp; Analytics" styleClass="label-header" />
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
        <VBox spacing="20">
            <VBox styleClass="card" spacing="10">
                <Label text="Bite Incidents by Animal Type" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: -fx-medical-red;" />
                <PieChart fx:id="animalTypeChart" prefHeight="300" />
            </VBox>
            
            <VBox styleClass="card" spacing="10">
                <Label text="Monthly Incident Trends" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: -fx-medical-red;" />
                <javafx.scene.chart.BarChart fx:id="monthlyChart" prefHeight="300">
                    <xAxis>
                        <javafx.scene.chart.CategoryAxis label="Month" />
                    </xAxis>
                    <yAxis>
                        <javafx.scene.chart.NumberAxis label="Number of Cases" />
                    </yAxis>
                </javafx.scene.chart.BarChart>
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>
