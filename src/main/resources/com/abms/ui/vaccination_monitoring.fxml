<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<VBox spacing="20" styleClass="root" stylesheets="@css/style.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.abms.ui.VaccinationController">
    <padding>
        <Insets top="20" left="20" right="20" bottom="20" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Button text="← Back" onAction="#goBack" style="-fx-background-color: transparent; -fx-text-fill: -fx-primary-blue;" />
        <ImageView fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="@images/logo.png" />
            </image>
        </ImageView>
        <Label text="Vaccination Schedule Monitoring" styleClass="label-header" />
    </HBox>

    <VBox VBox.vgrow="ALWAYS" styleClass="card" spacing="10">
        <Label text="Pending Vaccinations" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: -fx-highlight-orange;" />
        
        <TableView fx:id="vaccinationTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="idCol" text="ID" prefWidth="50" />
                <TableColumn fx:id="patientCol" text="Patient Name" prefWidth="200" />
                <TableColumn fx:id="doseCol" text="Dose #" prefWidth="100" />
                <TableColumn fx:id="dateCol" text="Scheduled Date" prefWidth="150" />
                <TableColumn fx:id="statusCol" text="Status" prefWidth="150" />
            </columns>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Button text="Mark as Completed" onAction="#markCompleted" style="-fx-background-color: -fx-success-green;" />
        </HBox>
    </VBox>
</VBox>
