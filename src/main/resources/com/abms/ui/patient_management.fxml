<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<VBox spacing="20" styleClass="root" stylesheets="@css/style.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.abms.ui.PatientController">
    <padding>
        <Insets top="20" left="20" right="20" bottom="20" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Button text="← Back" onAction="#goBack" style="-fx-background-color: transparent; -fx-text-fill: -fx-primary-blue;" />
        <ImageView fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="@../../../images/animal.png" />
            </image>
        </ImageView>
        <Label text="Patient Registration &amp; Incident Recording" styleClass="label-header" />
    </HBox>

    <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE" styleClass="card">
        <Tab text="Registration">
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                <VBox spacing="20">
                    <padding>
                        <Insets top="10" left="10" right="10" bottom="10" />
                    </padding>
                    <!-- Patient Information Section -->
                    <VBox styleClass="card" spacing="15">
                        <Label text="Patient Information" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: -fx-primary-blue;" />
                        <GridPane hgap="15" vgap="15">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50" />
                                <ColumnConstraints percentWidth="50" />
                            </columnConstraints>
                            
                            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label text="First Name" />
                                <TextField fx:id="firstNameField" />
                            </VBox>
                            <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label text="Last Name" />
                                <TextField fx:id="lastNameField" />
                            </VBox>
                            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <Label text="Age" />
                                <TextField fx:id="ageField" />
                            </VBox>
                            <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <Label text="Gender" />
                                <ComboBox fx:id="genderCombo" maxWidth="Infinity" />
                            </VBox>
                            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="2">
                                <Label text="Address" />
                                <TextArea fx:id="addressArea" prefHeight="60" />
                            </VBox>
                            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="3">
                                <Label text="Contact Number" />
                                <TextField fx:id="contactField" />
                            </VBox>
                        </GridPane>
                    </VBox>

                    <!-- Bite Incident Section -->
                    <VBox styleClass="card" spacing="15">
                        <Label text="Bite Incident Details" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: -fx-medical-red;" />
                        <GridPane hgap="15" vgap="15">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="33" />
                                <ColumnConstraints percentWidth="33" />
                                <ColumnConstraints percentWidth="33" />
                            </columnConstraints>
                            
                            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label text="Date of Bite" />
                                <DatePicker fx:id="biteDatePicker" maxWidth="Infinity" />
                            </VBox>
                            <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label text="Animal Type" />
                                <ComboBox fx:id="animalTypeCombo" maxWidth="Infinity" />
                            </VBox>
                            <VBox spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                <Label text="Bite Site (e.g. Leg, Hand)" />
                                <TextField fx:id="biteSiteField" />
                            </VBox>
                            
                            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <Label text="Animal Status" />
                                <ComboBox fx:id="animalStatusCombo" maxWidth="Infinity" />
                            </VBox>
                            <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <Label text="Exposure Category" />
                                <ComboBox fx:id="exposureTypeCombo" maxWidth="Infinity" />
                            </VBox>
                            
                            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="3">
                                <Label text="Remarks" />
                                <TextArea fx:id="remarksArea" prefHeight="60" />
                            </VBox>
                        </GridPane>
                    </VBox>

                    <HBox alignment="CENTER_RIGHT" spacing="10">
                        <Button text="Cancel" style="-fx-background-color: transparent; -fx-text-fill: gray;" />
                        <Button text="Save Patient &amp; Incident" onAction="#handleSave" prefWidth="200" style="-fx-background-color: -fx-success-green;" />
                    </HBox>
                </VBox>
            </ScrollPane>
        </Tab>
        <Tab text="Patient List">
            <VBox spacing="15" styleClass="card">
                <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                <TableView fx:id="patientTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idCol" text="ID" prefWidth="50" />
                        <TableColumn fx:id="firstNameCol" text="First Name" prefWidth="150" />
                        <TableColumn fx:id="lastNameCol" text="Last Name" prefWidth="150" />
                        <TableColumn fx:id="ageCol" text="Age" prefWidth="50" />
                        <TableColumn fx:id="genderCol" text="Gender" prefWidth="80" />
                        <TableColumn fx:id="contactCol" text="Contact Number" prefWidth="150" />
                        <TableColumn fx:id="addressCol" text="Address" prefWidth="250" />
                    </columns>
                </TableView>
            </VBox>
        </Tab>
    </TabPane>
</VBox>
